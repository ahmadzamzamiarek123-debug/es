# ============================================================================
# Es Lilin Tracker — contoh environment variables (TANPA nilai rahasia)
# Salin file ini menjadi `.env.local` lalu isi nilainya. JANGAN commit `.env*`.
# ============================================================================

# --- Database Neon (DUA koneksi, role berbeda) ---
# Gunakan connection string POOLED milik Neon, wajib sslmode=require.
# bot_writer: dipakai bot untuk menulis. web_reader: dipakai web (read-only).
DATABASE_URL_BOT=postgresql://bot_writer:PASSWORD@HOST.neon.tech/DB?sslmode=require
DATABASE_URL_WEB=postgresql://web_reader:PASSWORD@HOST.neon.tech/DB?sslmode=require

# --- Telegram ---
TELEGRAM_BOT_TOKEN=            # token dari @BotFather
TELEGRAM_WEBHOOK_SECRET=      # string acak panjang buatan sendiri (mis. 32+ char hex)
ALLOWED_TELEGRAM_ID=          # user id Telegram pemilik (angka)

# --- Gemini ---
GEMINI_API_KEY=              # API key Google AI Studio (free tier)
GEMINI_MODEL=gemini-2.0-flash # opsional; default gemini-2.0-flash

# --- Web dashboard auth ---
DASHBOARD_PASSWORD=          # password login dashboard (sederhana)

# --- Base URL (untuk scripts/set-webhook.ts) ---
PUBLIC_BASE_URL=https://your-app.vercel.app
